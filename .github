name: Build Android APK

# Builds an installable Android APK in the cloud — no Android Studio needed.
# - Runs on every push to main/master (and can be started manually).
# - Pushing a tag like v1.0 also publishes the APK as a GitHub Release.

on:
  push:
    branches: [ main, master ]
    tags: [ 'v*' ]
  workflow_dispatch:

permissions:
  contents: write

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Set up Node.js
        uses: actions/setup-node@v4
        with:
          node-version: '20'

      - name: Set up Java (JDK 17)
        uses: actions/setup-java@v4
        with:
          distribution: 'temurin'
          java-version: '17'

      - name: Set up Android SDK
        uses: android-actions/setup-android@v3

      - name: Install dependencies
        run: npm install

      - name: Add Android platform
        run: |
          if [ ! -d "android" ]; then
            npx cap add android
          fi

      - name: Generate app icons & splash
        run: npx capacitor-assets generate --android || echo "icon generation skipped"

      - name: Sync web assets into Android project
        run: npx cap sync android

      - name: Build debug APK
        run: |
          cd android
          chmod +x gradlew
          ./gradlew assembleDebug --no-daemon

      - name: Rename APK
        run: cp android/app/build/outputs/apk/debug/app-debug.apk ClassAI-EN6.apk

      - name: Upload APK artifact
        uses: actions/upload-artifact@v4
        with:
          name: ClassAI-EN6-apk
          path: ClassAI-EN6.apk
          if-no-files-found: error

      - name: Publish Release (only when a tag is pushed)
        if: startsWith(github.ref, 'refs/tags/')
        uses: softprops/action-gh-release@v2
        with:
          files: ClassAI-EN6.apk
